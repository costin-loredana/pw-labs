---
import BaseLayout from '../layouts/BaseLayout.astro';
---
<BaseLayout title="Contact si Programare" activePage="contact">

  <section class="bg-gradient-to-br from-sky-50 via-white to-blue-50 pt-10 pb-12 md:pt-16 md:pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Suntem aproape de tine</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-slate-900 max-w-2xl leading-tight mb-3">Contact si Programare</h1>
      <p class="text-slate-500 text-base md:text-lg max-w-xl leading-relaxed">Ia legatura cu noi sau programeaza-te online. Echipa noastra iti raspunde in cel mult 2 ore in zilele lucratoare.</p>
    </div>
  </section>

  <section class="py-10 md:py-16 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-3 gap-6 md:gap-8">
        <div class="flex flex-col gap-3 md:gap-6">

          <div class="flex items-start gap-3 p-4 rounded-xl bg-red-50 border border-red-100 md:hidden">
            <div class="w-8 h-8 rounded-lg bg-red-100 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-red-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M12 9v2m0 4h.01m-6.938 4h13.856c1.54 0 2.502-1.667 1.732-3L13.732 4c-.77-1.333-2.694-1.333-3.464 0L3.34 16c-.77 1.333.192 3 1.732 3z"/></svg>
            </div>
            <div>
              <div class="font-bold text-red-700 text-sm">Urgente ORL</div>
              <div class="text-red-600 text-xs mt-0.5">Sunati la 112 sau veniti direct la urgente.</div>
            </div>
          </div>

          <div class="flex items-start gap-3 p-4 rounded-xl border border-slate-100 md:p-6 md:rounded-2xl hover:border-sky-100 hover:shadow-lg transition-all">
            <div class="w-9 h-9 rounded-xl bg-sky-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M17.657 16.657L13.414 20.9a1.998 1.998 0 01-2.827 0l-4.244-4.243a8 8 0 1111.314 0z"/><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M15 11a3 3 0 11-6 0 3 3 0 016 0z"/></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-sm">Adresa</div>
              <div class="text-slate-500 text-xs mt-0.5">Str. Testemitanu 29, Chisinau</div>
            </div>
          </div>

          <a href="tel:+37322000000" class="flex items-start gap-3 p-4 rounded-xl border border-slate-100 md:p-6 md:rounded-2xl hover:border-sky-100 hover:shadow-lg transition-all">
            <div class="w-9 h-9 rounded-xl bg-sky-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-sm">Telefon</div>
              <div class="text-sky-600 font-semibold text-sm mt-0.5">+373 22 000 000</div>
              <div class="text-slate-400 text-xs">Luni – Vineri: 08:00 – 17:00</div>
            </div>
          </a>

          <a href="mailto:orl@spital.md" class="flex items-start gap-3 p-4 rounded-xl border border-slate-100 md:p-6 md:rounded-2xl hover:border-sky-100 hover:shadow-lg transition-all">
            <div class="w-9 h-9 rounded-xl bg-sky-50 flex items-center justify-center flex-shrink-0">
              <svg class="w-4 h-4 text-sky-600" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 8l7.89 5.26a2 2 0 002.22 0L21 8M5 19h14a2 2 0 002-2V7a2 2 0 00-2-2H5a2 2 0 00-2 2v10a2 2 0 002 2z"/></svg>
            </div>
            <div>
              <div class="font-bold text-slate-900 text-sm">Email</div>
              <div class="text-sky-600 font-semibold text-sm mt-0.5">orl@spital.md</div>
            </div>
          </a>
        </div>

        <div class="lg:col-span-2 bg-slate-100 rounded-2xl overflow-hidden min-h-48 flex items-center justify-center">
          <div class="text-center p-8">
            <svg class="w-10 h-10 text-slate-300 mx-auto mb-3" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1.5" d="M9 20l-5.447-2.724A1 1 0 013 16.382V5.618a1 1 0 011.447-.894L9 7m0 13l6-3m-6 3V7m6 10l4.553 2.276A1 1 0 0021 18.382V7.618a1 1 0 00-.553-.894L15 4m0 13V4m0 0L9 7"/></svg>
            <div class="text-slate-400 text-sm font-medium">Str. Testemitanu 29, Chisinau</div>
            <a href="https://maps.google.com/?q=Str.+Testemitanu+29+Chisinau" target="_blank" rel="noopener" class="mt-3 inline-block text-xs font-bold text-sky-600 hover:underline">Deschide in Google Maps &rarr;</a>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="programare" class="py-12 md:py-20 bg-slate-50">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-12">
        <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Pas simplu, ingrijire rapida</p>
        <h2 class="font-display text-2xl md:text-4xl font-bold text-slate-900 mb-2">Fa o Programare</h2>
        <p class="text-slate-500 text-sm md:text-base">Completeaza formularul si te contactam in maxim 2 ore in zilele lucratoare.</p>
      </div>
      <form id="appointment-form" class="bg-white rounded-2xl border border-slate-100 shadow-sm p-5 md:p-8 flex flex-col gap-4">
        <div class="grid grid-cols-1 sm:grid-cols-2 gap-4">
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Nume</label>
            <input type="text" placeholder="Numele dvs." required class="px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm">
          </div>
          <div class="flex flex-col gap-1.5">
            <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Prenume</label>
            <input type="text" placeholder="Prenumele dvs." required class="px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm">
          </div>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Numar de telefon</label>
          <input type="tel" placeholder="+373 XX XXX XXX" required class="px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Email (optional)</label>
          <input type="email" placeholder="email@exemplu.md" class="px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Motivul vizitei</label>
          <select required class="px-4 py-3 rounded-xl border border-slate-200 text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm bg-white">
            <option value="">Selecteaza motivul vizitei</option>
            <option>Durere de urechi / Auz diminuat</option>
            <option>Probleme de sinusuri / Nas infundat</option>
            <option>Probleme de gat / Voce</option>
            <option>Control periodic ORL</option>
            <option>ORL Pediatric (copil)</option>
            <option>Altceva</option>
          </select>
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Data preferata</label>
          <input type="date" class="px-4 py-3 rounded-xl border border-slate-200 text-slate-700 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm">
        </div>
        <div class="flex flex-col gap-1.5">
          <label class="text-xs font-semibold text-slate-600 uppercase tracking-wide">Mesaj (optional)</label>
          <textarea rows="3" placeholder="Descrie pe scurt simptomele sau intrebarile tale..." class="px-4 py-3 rounded-xl border border-slate-200 text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-sky-400 focus:border-transparent text-sm resize-none"></textarea>
        </div>
        <button type="submit" class="bg-sky-600 hover:bg-sky-700 active:bg-sky-800 text-white py-4 rounded-xl font-bold text-sm transition-colors shadow-lg shadow-sky-100 mt-1">
          Trimite solicitarea de programare
        </button>
        <p class="text-center text-xs text-slate-400">Va contactam telefonic in maxim 2 ore pentru confirmare.</p>
      </form>
    </div>
  </section>

</BaseLayout>