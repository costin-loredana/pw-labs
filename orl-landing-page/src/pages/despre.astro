---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const doctors = await getCollection('doctors');
const sortedDoctors = doctors.sort((a, b) => a.data.order - b.data.order);
---
<BaseLayout title="Despre Noi" activePage="despre">

  <section class="bg-gradient-to-br from-sky-50 via-white to-blue-50 pt-10 pb-12 md:pt-16 md:pb-20">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Istoria noastra</p>
      <h1 class="font-display text-3xl md:text-5xl font-bold text-slate-900 max-w-2xl leading-tight mb-3">Despre Departamentul ORL</h1>
      <p class="text-slate-500 text-base md:text-lg max-w-2xl leading-relaxed">Cu peste doua decenii de experienta, Departamentul ORL al Spitalului Republican este un centru de referinta national pentru diagnosticul si tratamentul afectiunilor urechii, nasului si gatului.</p>
    </div>
  </section>

  <section class="py-10 md:py-20 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-1 lg:grid-cols-2 gap-8 md:gap-12 items-center">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Misiunea noastra</p>
          <h2 class="font-display text-2xl md:text-3xl font-bold text-slate-900 mb-4">Sanatate, Inovatie, Compasiune</h2>
          <p class="text-slate-500 leading-relaxed mb-3 text-sm md:text-base">Ne dedicam oferirii de ingrijiri medicale de cea mai inalta calitate, intr-un mediu cald si prietenos. Fiecare pacient este tratat cu respect, empatie si profesionalism.</p>
          <p class="text-slate-500 leading-relaxed mb-5 text-sm md:text-base">Investim constant in tehnologie medicala moderna si in formarea continua a echipei noastre.</p>
          <div class="flex flex-wrap gap-2">
            {['Acreditare JCI', 'Tehnologie FESS 4K', 'ORL Pediatric'].map(badge => (
              <span class="inline-flex items-center gap-1.5 bg-sky-50 text-sky-700 text-xs font-semibold px-3 py-2 rounded-full">
                <svg class="w-3.5 h-3.5" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M9 12l2 2 4-4m6 2a9 9 0 11-18 0 9 9 0 0118 0z"/></svg>
                {badge}
              </span>
            ))}
          </div>
        </div>
        <div class="rounded-2xl md:rounded-3xl overflow-hidden shadow-xl shadow-sky-100 aspect-[4/3] bg-gradient-to-br from-sky-100 to-blue-50 flex flex-col items-center justify-center text-sky-300 gap-3">
          <svg class="w-12 h-12 opacity-40" fill="none" viewBox="0 0 24 24" stroke="currentColor">
            <path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M19 21V5a2 2 0 00-2-2H7a2 2 0 00-2 2v16m14 0h2m-2 0h-5m-9 0H3m2 0h5M9 7h1m-1 4h1m4-4h1m-1 4h1m-5 10v-5a1 1 0 011-1h2a1 1 0 011 1v5m-4 0h4"/>
          </svg>
          <div class="text-center px-4">
            <p class="text-sky-400 font-semibold text-sm">Spitalul Republican</p>
            <p class="text-sky-300 text-xs mt-1">"Timofei Mosneaga" — Chisinau</p>
          </div>
        </div>
      </div>
    </div>
  </section>

  <section id="echipa" class="py-10 md:py-20 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-8 md:mb-14">
        <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Oamenii din spatele ingrijirii</p>
        <h2 class="font-display text-2xl md:text-4xl font-bold text-slate-900">Echipa Noastra</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-4 md:gap-8">
        {sortedDoctors.map(doc => (
          <div class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex md:block items-center gap-4 p-4 md:p-0">
              <div class="w-16 h-16 md:w-full md:h-auto md:aspect-square flex-shrink-0 rounded-xl md:rounded-none overflow-hidden bg-gradient-to-br from-sky-100 to-blue-50 flex items-center justify-center text-sky-200">
                <svg class="w-8 h-8 md:w-16 md:h-16" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="0.8" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div class="flex-1 md:p-5">
                <div class="text-xs font-bold tracking-widest uppercase text-sky-500 mb-0.5">{doc.data.role}</div>
                <h3 class="font-display font-bold text-base md:text-xl text-slate-900">{doc.data.name}</h3>
                <p class="text-slate-500 text-xs md:text-sm mt-1 leading-relaxed">{doc.data.bio}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
    </div>
  </section>

</BaseLayout>