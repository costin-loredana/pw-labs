---
import BaseLayout from '../layouts/BaseLayout.astro';
import { getCollection } from 'astro:content';

const allNews = await getCollection('news');
const latestNews = allNews
  .sort((a, b) => b.data.date.localeCompare(a.data.date))
  .slice(0, 3);

const doctors = await getCollection('doctors');
const sortedDoctors = doctors.sort((a, b) => a.data.order - b.data.order);

const categoryColors: Record<string, string> = {
  realizare: 'from-sky-500 to-blue-500',
  conferinta: 'from-emerald-500 to-teal-500',
  tehnologie: 'from-violet-500 to-purple-500',
  medic: 'from-amber-500 to-orange-500',
};
const categoryBadge: Record<string, string> = {
  realizare: 'bg-sky-50 text-sky-600',
  conferinta: 'bg-emerald-50 text-emerald-600',
  tehnologie: 'bg-violet-50 text-violet-600',
  medic: 'bg-amber-50 text-amber-600',
};
---
<BaseLayout title="Departamentul ORL" activePage="home">

  <!-- HERO -->
  <section class="relative overflow-hidden bg-gradient-to-br from-sky-50 via-white to-blue-50 pt-20 pb-24 md:pt-28 md:pb-32">
    <div class="absolute top-0 right-0 w-96 h-96 bg-sky-100 rounded-full opacity-40 blur-3xl -translate-y-1/2 translate-x-1/3"></div>
    <div class="absolute bottom-0 left-0 w-64 h-64 bg-blue-100 rounded-full opacity-30 blur-2xl translate-y-1/2 -translate-x-1/4"></div>
    <div class="relative max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="max-w-3xl">
        <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-4">Îngrijire Expertă — Urechi · Nas · Gât</p>
        <h1 class="block md:hidden font-display text-4xl font-bold text-slate-900 leading-tight mb-4">Sănătate ORL<br>pentru toată familia</h1>
        <h1 class="hidden md:block font-display text-5xl lg:text-6xl font-bold text-slate-900 leading-tight mb-6">Respiră mai bine.<br>Auzi mai clar.</h1>
        <p class="text-lg md:text-xl text-slate-500 max-w-xl mb-8">Diagnostic și tratament ORL specializat pentru toate vârstele, utilizând cea mai nouă tehnologie medicală, chiar în inima Chișinăului.</p>
        <div class="flex flex-col sm:flex-row gap-3">
          <a href="/contact#programare" class="bg-sky-600 hover:bg-sky-700 text-white px-7 py-4 rounded-full font-semibold text-center transition-all shadow-lg shadow-sky-200 hover:-translate-y-0.5">Fă o programare</a>
          <a href="tel:+37322000000" class="border border-slate-200 hover:bg-slate-50 text-slate-700 px-7 py-4 rounded-full font-semibold text-center transition-colors">Sună la recepție</a>
        </div>
      </div>
    </div>
  </section>

  <!-- SERVICES SUMMARY -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Ce oferim</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-slate-900">Serviciile Noastre</h2>
        <p class="text-slate-500 mt-3 max-w-lg mx-auto">Îngrijire completă pentru sănătatea simțurilor tale.</p>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-6">
        {[
          { title: 'Urechi și Auz', desc: 'Tratament pentru infecții, tinitus și adaptarea aparatelor auditive moderne.' },
          { title: 'Sinusuri și Nas', desc: 'Remedii pentru congestie cronică, alergii și presiune sinusală.' },
          { title: 'Gât și Voce', desc: 'Îngrijire specializată pentru amigdalită, efort vocal și probleme de deglutiție.' },
          { title: 'Chirurgie ORL', desc: 'Intervenții minim invazive, endoscopice pentru afecțiuni complexe.' },
          { title: 'ORL Pediatric', desc: 'Tratament specializat adaptat copiilor, într-un mediu prietenos și sigur.' },
          { title: 'Audiologie', desc: 'Evaluare auditivă completă și reabilitare prin proteze auditive moderne.' },
        ].map(s => (
          <div class="p-6 md:p-8 rounded-2xl border border-slate-100 hover:border-sky-100 bg-white hover:shadow-lg transition-all duration-300 hover:-translate-y-1">
            <h3 class="font-display font-bold text-base md:text-lg text-slate-900 mb-2">{s.title}</h3>
            <p class="text-slate-500 text-sm leading-relaxed">{s.desc}</p>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/servicii" class="inline-block border border-sky-200 text-sky-600 hover:bg-sky-50 px-6 py-3 rounded-full font-semibold text-sm transition-colors">Vezi toate serviciile</a>
      </div>
    </div>
  </section>

  <!-- TEAM -->
  <section class="py-20 md:py-28 bg-slate-50">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="text-center mb-14">
        <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Echipa noastră</p>
        <h2 class="font-display text-3xl md:text-4xl font-bold text-slate-900">Specialiștii Noștri</h2>
      </div>
      <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-3 gap-8">
        {sortedDoctors.map(doc => (
          <div class="bg-white rounded-2xl overflow-hidden border border-slate-100 hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class="flex md:block items-center gap-4 p-4 md:p-0">
              <div class="w-16 h-16 md:w-full md:h-auto md:aspect-square flex-shrink-0 rounded-xl md:rounded-none overflow-hidden bg-gradient-to-br from-sky-100 to-blue-50 flex items-center justify-center text-sky-300">
                <svg class="w-8 h-8 md:w-20 md:h-20" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="1" d="M16 7a4 4 0 11-8 0 4 4 0 018 0zM12 14a7 7 0 00-7 7h14a7 7 0 00-7-7z"/></svg>
              </div>
              <div class="flex-1 md:p-6">
                <div class="text-xs font-bold tracking-widest uppercase text-sky-500 mb-0.5">{doc.data.role}</div>
                <h3 class="font-display font-bold text-base md:text-xl text-slate-900">{doc.data.name}</h3>
                <p class="text-slate-500 text-xs md:text-sm mt-1 leading-relaxed">{doc.data.bio}</p>
              </div>
            </div>
          </div>
        ))}
      </div>
      <div class="text-center mt-10">
        <a href="/despre#echipa" class="inline-block border border-sky-200 text-sky-600 hover:bg-sky-50 px-6 py-3 rounded-full font-semibold text-sm transition-colors">Cunoaște întreaga echipă</a>
      </div>
    </div>
  </section>

  <!-- NEWS -->
  <section class="py-20 md:py-28 bg-white">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex flex-col sm:flex-row sm:items-end sm:justify-between mb-10 gap-4">
        <div>
          <p class="text-xs font-bold tracking-widest uppercase text-sky-600 mb-2">Ce s-a întâmplat recent</p>
          <h2 class="font-display text-3xl md:text-4xl font-bold text-slate-900">Noutăți și Realizări</h2>
        </div>
        <a href="/noutati" class="text-sm text-sky-600 font-semibold hover:underline shrink-0">Vezi toate →</a>
      </div>
      <div class="grid md:grid-cols-3 gap-6">
        {latestNews.map(item => (
          <article class="rounded-2xl border border-slate-100 overflow-hidden hover:shadow-xl transition-all duration-300 hover:-translate-y-1">
            <div class={`h-1.5 bg-gradient-to-r ${categoryColors[item.data.category]}`}></div>
            <div class="p-6">
              <div class="flex items-center gap-2 mb-3">
                <span class={`text-xs font-bold px-2.5 py-1 rounded-full ${categoryBadge[item.data.category]}`}>{item.data.category}</span>
                <span class="text-xs text-slate-400">{item.data.date}</span>
              </div>
              <h3 class="font-display font-bold text-lg text-slate-900 mb-2 leading-tight">{item.data.title}</h3>
              <p class="text-slate-500 text-sm leading-relaxed">{item.data.excerpt}</p>
            </div>
          </article>
        ))}
      </div>
    </div>
  </section>

  <!-- CTA BAND -->
  <section class="py-20 md:py-28 bg-sky-600">
    <div class="max-w-3xl mx-auto px-4 sm:px-6 lg:px-8 text-center">
      <h2 class="font-display text-3xl md:text-4xl font-bold text-white mb-4">Ești gata să te simți mai bine?</h2>
      <p class="text-sky-100 text-lg mb-10">Completează formularul și echipa noastră te va contacta în termen de 2 ore.</p>
      <form class="flex flex-col sm:flex-row flex-wrap gap-3 justify-center" id="hero-form">
        <input type="text" placeholder="Nume și Prenume" required class="flex-1 min-w-[200px] px-5 py-3.5 rounded-xl text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-white/50">
        <input type="tel" placeholder="Număr de telefon" required class="flex-1 min-w-[200px] px-5 py-3.5 rounded-xl text-slate-800 placeholder-slate-400 focus:outline-none focus:ring-2 focus:ring-white/50">
        <button type="submit" class="bg-white text-sky-600 hover:bg-sky-50 px-7 py-3.5 rounded-xl font-bold transition-colors shadow-lg">Trimite Solicitarea</button>
      </form>
    </div>
  </section>
  <div class="mascot-container">
    <div class="mascot-bubble">
      <p class="font-bold text-sky-600 mb-1">Bună! Sunt Dr. Orla</p>
      <p>Ai nevoie de ajutor cu o programare?</p>
      <span class="text-xs text-slate-400 mt-2 block">Click pentru contact</span>
    </div>
    <img 
      src="/assets/images/owl-mascot.png" 
      alt="ENT Mascot" 
      class="mascot-img"
    />
  </div>
</BaseLayout>
</BaseLayout>