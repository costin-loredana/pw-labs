---
interface Props {
  title: string;
  activePage?: string;
}
const { title, activePage } = Astro.props;
const navLinks = [
  { href: '/', label: 'Acasa', key: 'home' },
  { href: '/despre', label: 'Despre', key: 'despre' },
  { href: '/servicii', label: 'Servicii', key: 'servicii' },
  { href: '/noutati', label: 'Noutati', key: 'noutati' },
  { href: '/contact', label: 'Contact', key: 'contact' },
];
---
<!doctype html>
<html lang="ro">
<head>
  <meta charset="UTF-8" />
  <meta name="viewport" content="width=device-width, initial-scale=1" />
  <title>{title} — ORL Spitalul Republican</title>
  <link rel="icon" href="https://cdn-icons-png.flaticon.com/512/2864/2864448.png" type="image/png">
  <link href="https://fonts.googleapis.com/css2?family=Playfair+Display:wght@600;700&family=DM+Sans:wght@400;500;600&display=swap" rel="stylesheet">
  <link rel="stylesheet" href="/assets/css/style.css" />
  <link rel="stylesheet" href="/assets/css/orla.css" />
  <script is:inline src="https://identity.netlify.com/v1/netlify-identity-widget.js"></script>
</head>
<body class="font-body text-slate-800 bg-white">

  <header class="sticky top-0 z-50 bg-white/90 backdrop-blur-md border-b border-slate-100 shadow-sm">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="flex items-center justify-between h-16 md:h-20">
        <a href="/" class="flex items-center gap-3">
          <div class="w-10 h-10 rounded-xl bg-sky-600 flex items-center justify-center text-white font-bold text-lg shadow">H</div>
          <div class="leading-tight">
            <div class="font-display font-bold text-slate-800 text-sm">Spitalul Republican</div>
            <div class="text-xs text-sky-600 font-semibold">Departamentul ORL</div>
          </div>
        </a>
        <nav class="hidden md:flex items-center gap-6 text-sm font-medium text-slate-600">
          {navLinks.map(link => (
            <a href={link.href} class={`hover:text-sky-600 transition-colors ${activePage === link.key ? 'text-sky-600 font-bold' : ''}`}>
              {link.label}
            </a>
          ))}
          <a href="/contact#programare" class="bg-sky-600 hover:bg-sky-700 text-white px-5 py-2.5 rounded-full font-semibold transition-all shadow">Programare</a>
        </nav>
        <button id="menu-btn" class="md:hidden p-2 rounded-lg hover:bg-slate-50" aria-label="Deschide meniu">
          <span class="block w-6 h-0.5 bg-slate-700 mb-1.5" id="bar1"></span>
          <span class="block w-6 h-0.5 bg-slate-700 mb-1.5" id="bar2"></span>
          <span class="block w-6 h-0.5 bg-slate-700" id="bar3"></span>
        </button>
      </div>
    </div>
    <div id="mobile-menu" class="hidden md:hidden bg-white border-t border-slate-100 px-4 pb-5 shadow-lg">
      <nav class="flex flex-col gap-1 pt-3 text-sm font-medium">
        {navLinks.map(link => (
          <a href={link.href} class={`py-3 px-3 rounded-xl hover:bg-sky-50 hover:text-sky-600 transition-colors ${activePage === link.key ? 'bg-sky-50 text-sky-600 font-semibold' : ''}`}>
            {link.label}
          </a>
        ))}
        <a href="/contact#programare" class="mt-2 bg-sky-600 text-white text-center py-3.5 rounded-xl font-semibold">Programare rapida</a>
      </nav>
    </div>
  </header>

  <div class="fixed bottom-0 left-0 right-0 z-40 md:hidden bg-white border-t border-slate-200 px-4 py-3 shadow-lg">
    <div class="flex gap-2">
      <a href="tel:+37322000000" class="flex-1 flex items-center justify-center gap-2 border border-slate-200 text-slate-700 py-3 rounded-xl font-semibold text-sm">
        <svg class="w-4 h-4 flex-shrink-0" fill="none" viewBox="0 0 24 24" stroke="currentColor"><path stroke-linecap="round" stroke-linejoin="round" stroke-width="2" d="M3 5a2 2 0 012-2h3.28a1 1 0 01.948.684l1.498 4.493a1 1 0 01-.502 1.21l-2.257 1.13a11.042 11.042 0 005.516 5.516l1.13-2.257a1 1 0 011.21-.502l4.493 1.498a1 1 0 01.684.949V19a2 2 0 01-2 2h-1C9.716 21 3 14.284 3 6V5z"/></svg>
        Suna
      </a>
      <a href="/contact#programare" class="flex-1 bg-sky-600 text-white text-center py-3 rounded-xl font-semibold text-sm">Programare</a>
    </div>
  </div>

  <slot />

  <footer class="bg-slate-900 text-slate-400 py-10 md:py-14 pb-24 md:pb-14">
    <div class="max-w-6xl mx-auto px-4 sm:px-6 lg:px-8">
      <div class="grid grid-cols-2 md:grid-cols-4 gap-8 mb-8">
        <div class="col-span-2">
          <div class="flex items-center gap-3 mb-3">
            <div class="w-9 h-9 rounded-lg bg-sky-600 flex items-center justify-center text-white font-bold">H</div>
            <div>
              <div class="text-white font-semibold text-sm">Spitalul Republican</div>
              <div class="text-sky-400 text-xs">"Timofei Mosneaga" — ORL</div>
            </div>
          </div>
          <p class="text-sm leading-relaxed max-w-xs">Departament de excelenta pentru sanatatea urechilor, nasului si gatului.</p>
        </div>
        <div>
          <div class="text-white font-semibold text-sm mb-3">Navigatie</div>
          <ul class="space-y-2 text-sm">
            {navLinks.map(link => (
              <li><a href={link.href} class="hover:text-white transition-colors">{link.label}</a></li>
            ))}
          </ul>
        </div>
        <div>
          <div class="text-white font-semibold text-sm mb-3">Contact</div>
          <ul class="space-y-2 text-sm">
            <li>Str. Testemitanu 29</li>
            <li><a href="tel:+37322000000" class="hover:text-white transition-colors">+373 22 000 000</a></li>
            <li><a href="mailto:orl@spital.md" class="hover:text-white transition-colors">orl@spital.md</a></li>
          </ul>
        </div>
      </div>
      <div class="border-t border-slate-800 pt-5 text-center text-xs text-slate-600">
        &copy; {new Date().getFullYear()} Spitalul Republican "Timofei Mosneaga". Toate drepturile rezervate.
      </div>
    </div>
  </footer>

  <script>
    const menuBtn = document.getElementById('menu-btn');
    const mobileMenu = document.getElementById('mobile-menu');
    const bar1 = document.getElementById('bar1');
    const bar2 = document.getElementById('bar2');
    const bar3 = document.getElementById('bar3');

    if (menuBtn) {
      menuBtn.addEventListener('click', () => {
        const isHidden = mobileMenu.classList.toggle('hidden');
        bar1.style.transform = isHidden ? '' : 'translateY(6px) rotate(45deg)';
        bar2.style.opacity   = isHidden ? '' : '0';
        bar3.style.transform = isHidden ? '' : 'translateY(-6px) rotate(-45deg)';
      });
    }

    const form = document.getElementById('appointment-form') || document.getElementById('hero-form');
    if (form) {
      form.addEventListener('submit', (e) => {
        e.preventDefault();
        const btn = form.querySelector('button[type="submit"]');
        if (btn) {
          btn.textContent = 'Trimis! Va contactam in curand.';
          btn.disabled = true;
          btn.classList.replace('bg-sky-600', 'bg-emerald-600');
        }
      });
    }
  </script>

  <script is:inline>
    if (window.netlifyIdentity) {
      window.netlifyIdentity.on("init", user => {
        if (!user) {
          window.netlifyIdentity.on("login", () => {
            document.location.href = "/admin/";
          });
        }
      });
    }
  </script>

</body>
</html>